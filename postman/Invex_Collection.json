    {
      "name": "Auth",
      "description": "Login to get tokens for testing",
      "item": [
        {
          "name": "1. Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.token) {",
                  "    pm.environment.set('adminToken', res.token);",
                  "    pm.test('Login successful — token saved', () => pm.expect(res.success).to.be.true);",
                  "} else {",
                  "    pm.test('Login failed', () => pm.expect.fail(res.message));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "2. Register Staff User (for 403 tests)",
